
def insertionsort(My_List):
  for i in range(len(My_List)): 
    curr = My_List[i] 
    j = i-1
    while j >= 0 and curr < My_List[j] : 
      My_List[j + 1] = My_List[j]
      My_List[j] = curr
      j = j - 1

def PrintList(My_List):
  for i in My_List:
    print(i, end=" ")
  print("\n")
  
                
